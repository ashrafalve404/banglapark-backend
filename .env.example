# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/banglapark?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_very_long_and_random
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long_and_random
JWT_REFRESH_EXPIRY=7d

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Throttler ────────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
AUTH_THROTTLE_LIMIT=5

# ─── Cron ─────────────────────────────────────────────────────────────────────
CRON_TIMEZONE=Asia/Dhaka
DAILY_BENEFIT_CRON=0 0 * * *

# ─── Business Rules (also stored in DB for admin override) ────────────────────
QUALIFYING_ORDER_AMOUNT=2000
GENERATION_COMMISSION_AMOUNT=200
GENERATION_COMMISSION_LEVELS=10
ACTIVATION_PERIOD_DAYS=30
MIN_WITHDRAWAL_AMOUNT=1000
REFERRAL_BASE_URL=http://localhost:3000/register
